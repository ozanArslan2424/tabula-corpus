{
	"name": "@ozanarslan/corpus",
	"type": "module",
	"version": "0.1.4",
	"description": "Small Typescript backend framework with only core utilities",
	"author": "Ozan Arslan <ozanarslanwork@gmail.com>",
	"license": "MIT",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"homepage": "https://github.com/ozanArslan2424/corpus.git#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ozanArslan2424/corpus.git"
	},
	"keywords": [
		"bun serve",
		"backend framework",
		"simple"
	],
	"scripts": {
		"fm": "bunx --bun prettier --write .",
		"lint": "bunx oxlint -c ./.oxlintrc.json --fix",
		"build": "bun run build.ts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9",
		"arktype": "^2.1.29",
		"bun-plugin-dts": "^0.4.0",
		"oxlint": "^1.49.0",
		"prettier": "^3.8.1",
		"valibot": "^1.2.0",
		"zod": "^4.3.6",
		"memoirist": "^0.4.0"
	},
	"peerDependencies": {
		"typescript": "^5.9.3",
		"memoirist": "^0.4.0"
	},
	"peerDependenciesMeta": {
		"memoirist": {
			"optional": true
		}
	}
}
